# AWS Configuration
AWS_REGION=eu-central-1
BEDROCK_REGION=us-east-1

# DynamoDB Tables (from Amplify Gen 2)
CLINICAL_INTERACTION_TABLE=ClinicalInteraction-abc123xyz-main
CLINICAL_ENTITIES_TABLE=ClinicalEntities-abc123xyz-main
PATIENT_RECORD_TABLE=PatientRecord-abc123xyz-main
PATIENT_SUMMARY_TABLE=PatientSummary-abc123xyz-main

# AppSync Configuration
APPSYNC_ENDPOINT=https://your-appsync-endpoint.appsync-api.eu-central-1.amazonaws.com/graphql

# OpenSearch Configuration (optional)
OPENSEARCH_ENDPOINT=your-opensearch-endpoint.eu-central-1.aoss.amazonaws.com

# Agent Configuration
AGENT_VERSION=1.0.0
MAX_TOKENS=4096
TEMPERATURE=0.7
