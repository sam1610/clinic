        "position": {
          "x": 3200,
          "y": 40
        }
      }
    }
  },
  "Actions": [
    {
      "Identifier": "auth-set-logging",
      "Type": "UpdateFlowLoggingBehavior",
      "Parameters": {
        "FlowLoggingBehavior": "Enabled"
      },
      "Transitions": {
        "NextAction": "check-already-authed",
        "Errors": []
      }
    },
    {
      "Identifier": "check-already-authed",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.Attributes.PatientAuthenticated"
      },
      "Transitions": {
        "NextAction": "check-patient-registered",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "bedrock-supervisor-loop",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "true"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "check-patient-registered",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.Attributes.patientId"
      },
      "Transitions": {
        "NextAction": "play-not-registered",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "invoke-otp-generate",
            "Condition": {
              "Operator": "NotEqual",
              "Operands": [
                "UNKNOWN"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "play-not-registered",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "We could not find a registered account for your phone number. Please contact the clinic reception to register. Thank you.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "disconnect-auth",
        "Errors": []
      }
    },
    {
      "Identifier": "invoke-otp-generate",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "arn:aws:lambda:us-east-1:770961405135:function:clinical-otp-generate",
        "InvocationTimeLimitSeconds": "5",
        "LambdaInvocationAttributes": {
          "patientId": "$.Attributes.patientId",
          "patientPhone": "$.CustomerEndpoint.Address",
          "contactId": "$.ContactId"
        },
        "ResponseValidation": {
          "ResponseType": "JSON"
        }
      },
      "Transitions": {
        "NextAction": "play-otp-sent",
        "Errors": [
          {
            "NextAction": "play-auth-error",
            "ErrorType": "NoMatchingError"
          }
        ]
      }
    },
    {
      "Identifier": "play-otp-sent",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "For your security, we have sent a 6-digit verification code to your registered phone number. Please enter the code now.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "get-otp-input",
        "Errors": []
      }
    },
    {
      "Identifier": "get-otp-input",
      "Type": "GetParticipantInput",
      "Parameters": {
        "Text": "Please enter your 6-digit code.",
        "TextToSpeechType": "text",
        "InputTimeLimitSeconds": "60",
        "DTMF": {
          "NumberOfDigits": "6",
          "DisableCancelKey": "false"
        }
      },
      "Transitions": {
        "NextAction": "invoke-otp-validate",
        "Errors": [
          {
            "NextAction": "play-auth-error",
            "ErrorType": "InputTimeLimitExceeded"
          }
        ]
      }
    },
    {
      "Identifier": "invoke-otp-validate",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "arn:aws:lambda:us-east-1:770961405135:function:clinical-otp-validate",
        "InvocationTimeLimitSeconds": "5",
        "LambdaInvocationAttributes": {
          "patientId": "$.Attributes.patientId",
          "submittedCode": "$.Attributes.StoredCustomerInput",
          "contactId": "$.ContactId"
        },
        "ResponseValidation": {
          "ResponseType": "JSON"
        }
      },
      "Transitions": {
        "NextAction": "check-otp-result",
        "Errors": [
          {
            "NextAction": "play-auth-error",
            "ErrorType": "NoMatchingError"
          }
        ]
      }
    },
    {
      "Identifier": "check-otp-result",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.External.otpValid"
      },
      "Transitions": {
        "NextAction": "check-otp-attempts",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "set-auth-true",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "true"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "check-otp-attempts",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.External.blocked"
      },
      "Transitions": {
        "NextAction": "play-otp-wrong",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "play-blocked",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "true"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "set-auth-true",
      "Type": "UpdateContactAttributes",
      "Parameters": {
        "Attributes": [
          {
            "Key": "PatientAuthenticated",
            "Value": "true"
          },
          {
            "Key": "authSessionToken",
            "Value": "$.External.sessionToken",
            "Namespace": "External"
          },
          {
            "Key": "authTimestamp",
            "Value": "$.External.authTimestamp",
            "Namespace": "External"
          }
        ],
        "TargetContact": "Current"
      },
      "Transitions": {
        "NextAction": "play-auth-success",
        "Errors": []
      }
    },
    {
      "Identifier": "play-auth-success",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Identity confirmed. Welcome! How can I help you today?",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "bedrock-supervisor-loop",
        "Errors": []
      }
    },
    {
      "Identifier": "play-otp-wrong",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "The code you entered is incorrect or has expired. Please try again.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "get-otp-input",
        "Errors": []
      }
    },
    {
      "Identifier": "play-blocked",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "For security reasons, your verification has been blocked after multiple incorrect attempts. Please contact the clinic directly. Goodbye.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "disconnect-auth",
        "Errors": []
      }
    },
    {
      "Identifier": "bedrock-supervisor-loop",
      "Type": "GetParticipantInput",
      "Parameters": {
        "Text": "How can I assist you today?",
        "TextToSpeechType": "text",
        "InputTimeLimitSeconds": "30",
        "Speech": {
          "EndingSilenceDurationMs": "2500"
        }
      },
      "Transitions": {
        "NextAction": "invoke-bedrock-supervisor",
        "Errors": [
          {
            "NextAction": "play-auth-goodbye",
            "ErrorType": "InputTimeLimitExceeded"
          }
        ]
      }
    },
    {
      "Identifier": "invoke-bedrock-supervisor",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "arn:aws:lambda:us-east-1:770961405135:function:clinical-lex-fulfillment",
        "InvocationTimeLimitSeconds": "8",
        "LambdaInvocationAttributes": {
          "agentId": "PENDING_SUPERVISOR",
          "agentAliasId": "PENDING_ALIAS",
          "sessionId": "$.ContactId",
          "userInput": "$.Attributes.StoredCustomerInput",
          "patientId": "$.Attributes.patientId",
          "isAuthenticated": "$.Attributes.PatientAuthenticated",
          "authSessionToken": "$.Attributes.authSessionToken",
          "riskLevel": "$.Attributes.riskLevel",
          "channelType": "$.Attributes.channelType"
        },
        "ResponseValidation": {
          "ResponseType": "JSON"
        }
      },
      "Transitions": {
        "NextAction": "check-crisis-flag",
        "Errors": [
          {
            "NextAction": "play-auth-error",
            "ErrorType": "NoMatchingError"
          }
        ]
      }
    },
    {
      "Identifier": "check-crisis-flag",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.External.crisisDetected"
      },
      "Transitions": {
        "NextAction": "check-supervisor-action",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "invoke-crisis-escalation",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "true"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "invoke-crisis-escalation",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "arn:aws:lambda:us-east-1:770961405135:function:clinical-patient-lookup",
        "InvocationTimeLimitSeconds": "3",
        "LambdaInvocationAttributes": {
          "patientId": "$.Attributes.patientId",
          "contactId": "$.ContactId",
          "detectedSignal": "$.External.crisisKeyword"
        },
        "ResponseValidation": {
          "ResponseType": "JSON"
        }
      },
      "Transitions": {
        "NextAction": "transfer-crisis-queue",
        "Errors": [
          {
            "NextAction": "transfer-crisis-queue",
            "ErrorType": "NoMatchingError"
          }
        ]
      }
    },
    {
      "Identifier": "transfer-crisis-queue",
      "Type": "TransferContactToQueue",
      "Parameters": {
        "QueueLookupCode": "UrgentCrisisQueue"
      },
      "Transitions": {
        "NextAction": "play-auth-error",
        "Errors": [
          {
            "NextAction": "play-auth-error",
            "ErrorType": "QueueAtCapacity"
          }
        ]
      }
    },
    {
      "Identifier": "check-supervisor-action",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.External.action"
      },
      "Transitions": {
        "NextAction": "play-supervisor-response",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "transfer-agent-flow",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "TRANSFER_TO_AGENT"
              ]
            }
          },
          {
            "NextAction": "play-supervisor-response",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "RESPOND"
              ]
            }
          },
          {
            "NextAction": "play-auth-goodbye",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "END_SESSION"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "play-supervisor-response",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "$.External.agentResponse",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "check-continue-auth",
        "Errors": []
      }
    },
    {
      "Identifier": "check-continue-auth",
      "Type": "GetParticipantInput",
      "Parameters": {
        "Text": "Is there anything else I can help you with? Press 1 to continue, press 2 to speak with an agent, or press 3 to end.",
        "TextToSpeechType": "text",
        "InputTimeLimitSeconds": "10",
        "DTMF": {
          "NumberOfDigits": "1",
          "DisableCancelKey": "false"
        }
      },
      "Transitions": {
        "NextAction": "play-auth-goodbye",
        "Errors": [
          {
            "NextAction": "play-auth-goodbye",
            "ErrorType": "InputTimeLimitExceeded"
          }
        ],
        "Conditions": [
          {
            "NextAction": "bedrock-supervisor-loop",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "1"
              ]
            }
          },
          {
            "NextAction": "transfer-agent-flow",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "2"
              ]
            }
          },
          {
            "NextAction": "play-auth-goodbye",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "3"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "transfer-agent-flow",
      "Type": "TransferToFlow",
      "Parameters": {
        "ContactFlowId": "arn:aws:connect:us-east-1:770961405135:instance/0cb42924-3bcc-4f0b-a7d0-dbf5770fabfd/contact-flow/70c3bbef-936d-4de1-8d9c-d39b32649e61"
      },
      "Transitions": {
        "NextAction": "play-auth-error",
        "Errors": []
      }
    },
    {
      "Identifier": "play-auth-error",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "We are experiencing a technical issue. Connecting you to an agent now. Please hold.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "transfer-agent-flow",
        "Errors": []
      }
    },
    {
      "Identifier": "play-auth-goodbye",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Thank you for contacting DigiCall Clinic. Take care and goodbye.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "disconnect-auth",
        "Errors": []
      }
    },
    {
      "Identifier": "disconnect-auth",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    }
  ]
}