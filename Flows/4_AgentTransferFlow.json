        }
      },
      "route-to-general-queue": {
        "position": {
          "x": 1300,
          "y": 40
        }
      },
      "play-transfer-error": {
        "position": {
          "x": 1500,
          "y": 320
        }
      },
      "disconnect-transfer": {
        "position": {
          "x": 1700,
          "y": 320
        }
      }
    }
  },
  "Actions": [
    {
      "Identifier": "transfer-set-logging",
      "Type": "UpdateFlowLoggingBehavior",
      "Parameters": {
        "FlowLoggingBehavior": "Enabled"
      },
      "Transitions": {
        "NextAction": "invoke-context-packager",
        "Errors": []
      }
    },
    {
      "Identifier": "invoke-context-packager",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "arn:aws:lambda:us-east-1:770961405135:function:clinical-patient-lookup",
        "InvocationTimeLimitSeconds": "5",
        "LambdaInvocationAttributes": {
          "patientId": "$.Attributes.patientId",
          "isAuthenticated": "$.Attributes.PatientAuthenticated",
          "riskLevel": "$.Attributes.riskLevel",
          "channelType": "$.Attributes.channelType",
          "sessionType": "$.Attributes.sessionType",
          "agentType": "$.Attributes.agentType",
          "contactId": "$.ContactId",
          "authSessionToken": "$.Attributes.authSessionToken"
        },
        "ResponseValidation": {
          "ResponseType": "JSON"
        }
      },
      "Transitions": {
        "NextAction": "set-packaged-context",
        "Errors": [
          {
            "NextAction": "set-whisper-flow",
            "ErrorType": "NoMatchingError"
          }
        ]
      }
    },
    {
      "Identifier": "set-packaged-context",
      "Type": "UpdateContactAttributes",
      "Parameters": {
        "Attributes": [
          {
            "Key": "patientSummary",
            "Value": "$.External.patientSummary",
            "Namespace": "External"
          },
          {
            "Key": "recentInteractions",
            "Value": "$.External.recentInteractions",
            "Namespace": "External"
          },
          {
            "Key": "activePrescriptions",
            "Value": "$.External.activePrescriptions",
            "Namespace": "External"
          },
          {
            "Key": "conversationHistory",
            "Value": "$.External.conversationHistory",
            "Namespace": "External"
          },
          {
            "Key": "transferReason",
            "Value": "$.External.transferReason",
            "Namespace": "External"
          }
        ],
        "TargetContact": "Current"
      },
      "Transitions": {
        "NextAction": "check-risk-level",
        "Errors": []
      }
    },
    {
      "Identifier": "check-risk-level",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.Attributes.riskLevel"
      },
      "Transitions": {
        "NextAction": "play-transfer-hold",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "play-crisis-holding",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "CRISIS"
              ]
            }
          },
          {
            "NextAction": "play-transfer-hold",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "HIGH"
              ]
            }
          },
          {
            "NextAction": "play-transfer-hold",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "MEDIUM"
              ]
            }
          },
          {
            "NextAction": "play-transfer-hold",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "LOW"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "play-crisis-holding",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "I can hear that you are going through a very difficult moment. You are not alone. I am connecting you immediately to a specialist who can help. Please stay on the line.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "set-whisper-flow",
        "Errors": []
      }
    },
    {
      "Identifier": "play-transfer-hold",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "I am now connecting you to a specialist agent who has full context of our conversation. You will not need to repeat anything. Please hold for a moment.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "set-whisper-flow",
        "Errors": []
      }
    },
    {
      "Identifier": "set-whisper-flow",
      "Type": "UpdateContactAttributes",
      "Parameters": {
        "Attributes": [
          {
            "Key": "whisperEnabled",
            "Value": "true"
          }
        ],
        "TargetContact": "Current"
      },
      "Transitions": {
        "NextAction": "route-to-medical-queue",
        "Errors": []
      }
    },
    {
      "Identifier": "route-to-crisis-queue",
      "Type": "TransferContactToQueue",
      "Parameters": {
        "QueueLookupCode": "UrgentCrisisQueue",
        "AgentWhisperFlowId": "arn:aws:connect:us-east-1:770961405135:instance/0cb42924-3bcc-4f0b-a7d0-dbf5770fabfd/contact-flow/ac836471-28e2-414f-adff-4d321fefdec8"
      },
      "Transitions": {
        "NextAction": "play-transfer-error",
        "Errors": [
          {
            "NextAction": "play-transfer-error",
            "ErrorType": "QueueAtCapacity"
          }
        ]
      }
    },
    {
      "Identifier": "route-to-medical-queue",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.Attributes.riskLevel"
      },
      "Transitions": {
        "NextAction": "route-to-general-queue",
        "Errors": [],
        "Conditions": [
          {
            "NextAction": "route-to-crisis-queue",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "CRISIS"
              ]
            }
          },
          {
            "NextAction": "transfer-medical",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "HIGH"
              ]
            }
          },
          {
            "NextAction": "transfer-medical",
            "Condition": {
              "Operator": "Equals",
              "Operands": [
                "MEDIUM"
              ]
            }
          }
        ]
      }
    },
    {
      "Identifier": "transfer-medical",
      "Type": "TransferContactToQueue",
      "Parameters": {
        "QueueLookupCode": "MedicalSupportQueue",
        "AgentWhisperFlowId": "arn:aws:connect:us-east-1:770961405135:instance/0cb42924-3bcc-4f0b-a7d0-dbf5770fabfd/contact-flow/ac836471-28e2-414f-adff-4d321fefdec8"
      },
      "Transitions": {
        "NextAction": "play-transfer-error",
        "Errors": [
          {
            "NextAction": "route-to-general-queue",
            "ErrorType": "QueueAtCapacity"
          }
        ]
      }
    },
    {
      "Identifier": "route-to-general-queue",
      "Type": "TransferContactToQueue",
      "Parameters": {
        "QueueLookupCode": "GeneralInfoQueue",
        "AgentWhisperFlowId": "arn:aws:connect:us-east-1:770961405135:instance/0cb42924-3bcc-4f0b-a7d0-dbf5770fabfd/contact-flow/ac836471-28e2-414f-adff-4d321fefdec8"
      },
      "Transitions": {
        "NextAction": "play-transfer-error",
        "Errors": [
          {
            "NextAction": "play-transfer-error",
            "ErrorType": "QueueAtCapacity"
          }
        ]
      }
    },
    {
      "Identifier": "play-transfer-error",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "All agents are currently busy. Please call back shortly or leave a message. We apologize for the inconvenience.",
        "TextToSpeechType": "text"
      },
      "Transitions": {
        "NextAction": "disconnect-transfer",
        "Errors": []
      }
    },
    {
      "Identifier": "disconnect-transfer",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    }
  ]
}